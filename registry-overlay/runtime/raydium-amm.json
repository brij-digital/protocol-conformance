        "user_lp_token_account": "$input.user_lp_token_account",
        "owner": "$wallet",
        "market_event_queue": "$input.market_event_queue"
      }
    },
    "add_liquidity_fixed_quote": {
      "instruction": "add_liquidity",
      "args": {
