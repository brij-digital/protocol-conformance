        "market_base_vault": "$input.market_base_vault",
        "market_quote_vault": "$input.market_quote_vault",
        "market_authority": "$input.market_authority",
        "user_lp_token_account": "$input.user_lp_token_account",
        "user_base_token_account": "$input.user_base_token_account",
        "user_quote_token_account": "$input.user_quote_token_account",
        "owner": "$wallet",
