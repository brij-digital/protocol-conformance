{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@brij-digital/apppack-runtime": ["../protocol-runtime/src/index.ts"],
      "@brij-digital/apppack-runtime/*": ["../protocol-runtime/src/*.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist",
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
